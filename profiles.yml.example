predictive_ltv_survival_pipeline:
  target: dev
  outputs:
    dev:
      type: databricks
      catalog: main
      schema: ltv_dev
      host: "{{ env_var('DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DATABRICKS_HTTP_PATH') }}"
      token: "{{ env_var('DATABRICKS_TOKEN') }}"
      threads: 4
