# Local environment template for development.
# Copy to .env.local and update real values where needed.

# dbt profile resolution for local/VS Code extension workflows
DBT_PROFILES_DIR=.

# Databricks credentials (set real values before dbt debug/run)
DATABRICKS_HOST=https://example.databricks.com
DATABRICKS_HTTP_PATH=/sql/protocolv1/o/0/0000000000000000
DATABRICKS_TOKEN=dapi-placeholder-token

# GitHub API token for authenticated workflow polling (repo:read scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
